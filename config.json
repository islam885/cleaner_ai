{
  "training": {
    "epochs": 100,
    "batch_size": 16,
    "learning_rate": 0.001,
    "image_size": 256,
    "dataset_size": 10000,
    "mixed_precision": true,
    "num_workers": 4,
    "seed": 42
  },
  "model": {
    "base_channels": 64,
    "in_channels": 3,
    "out_channels": 3,
    "use_discriminator": true
  },
  "data": {
    "augmentation": true,
    "cache_enabled": false,
    "train_split": 0.8,
    "val_split": 0.1,
    "test_split": 0.1
  },
  "inference": {
    "batch_size": 32,
    "device": "auto"
  },
  "paths": {
    "data_dir": "data",
    "models_dir": "models",
    "logs_dir": "logs",
    "checkpoint_dir": "models"
  }
}
